filter(estrato == est) %>%
pull(nh)
if (length(n_sample) == 0 || n_sample == 0) return(NULL)
df_out <- generate_random_frame(
data     = df,
id_psu   = id_upm,
strata   = estrato,
size_var = Mi,
permanent_random =  df$nap,
n_sample = n_sample,
method   = "Pareto"
) %>%
arrange(Xi_Pareto)
return(df_out)
})
